{
  "version": 2,
  "buildCommand": "cd panel && npm install && npm run build",
  "outputDirectory": "panel/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
